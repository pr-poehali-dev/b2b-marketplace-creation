{
  "tests": [
    {
      "name": "OPTIONS CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Send code invalid phone",
      "method": "POST",
      "path": "/",
      "body": {"action": "send_code", "phone": "123"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login without password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "phone": "+79991234567", "password": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong credentials",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "phone": "+79990000000", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Register short password",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "phone": "+79991234567", "code": "1234", "password": "12"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me without token",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
